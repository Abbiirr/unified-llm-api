# =============================================================================
# LiteLLM Unified Free Gateway — Environment Setup
# Last audited against live provider endpoints on 2026-04-20.
#
# QUICK START:
#   1. cp .env.template .env
#   2. Fill in at least GEMINI + GROQ keys below (~5 min)
#   3. bash scripts/start.sh
#   4. nohup bash scripts/watchdog.sh >> logs/watchdog.log 2>&1 &
#   5. Gateway is live at http://localhost:4000/v1
#
# MINIMUM VIABLE: GEMINI_API_KEY + GROQ_API_KEY = ~15K free requests/day
# FULL SETUP:     All 10 providers = ~160K+ free requests/day
# =============================================================================

# Your gateway password. All client apps send this to authenticate.
# Change it to something secret (e.g. sk-my-llm-gateway-2026).
LITELLM_MASTER_KEY=sk-change-me

# ---------------------------------------------------------------------------
# 1. GOOGLE AI STUDIO — best free tier, start here
#    Free: Gemini 2.5 Pro (5 RPM), Flash (10 RPM), Flash-Lite (15 RPM)
#    No credit card. No phone.
#
#    1. Go to https://aistudio.google.com/apikey
#    2. Click "Create API key" → select a project
#    3. Copy the key (starts with "AIza...")
# ---------------------------------------------------------------------------
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# 2. CEREBRAS — blazing fast hardware-accelerated inference
#    Free: 30 RPM, 1M tokens/day per model
#    No credit card. No phone.
#
#    1. Go to https://cloud.cerebras.ai/
#    2. Sign up → go to "API Keys" in sidebar → "Create API Key"
#    3. Copy the key (starts with "csk-...")
# ---------------------------------------------------------------------------
CEREBRAS_API_KEY=

# ---------------------------------------------------------------------------
# 3. GROQ — fast inference, many models
#    Free: 1K-14K requests/day depending on model
#    No credit card. No phone.
#
#    1. Go to https://console.groq.com/keys
#    2. Sign up → "Create API Key"
#    3. Copy the key (starts with "gsk_...")
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# 4. GITHUB MODELS — free with any GitHub account
#    Free: depends on Copilot tier (Free tier available)
#    No credit card. No phone.
#
#    1. Go to https://github.com/settings/tokens?type=beta
#    2. "Generate new token" → name it "llm-gateway"
#    3. Under Permissions → Account → find "Models" → set to "Read-only"
#    4. Copy the token (starts with "github_pat_...")
# ---------------------------------------------------------------------------
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# 5. MISTRAL — massive 1 BILLION tokens/month allowance
#    Free "Experiment" plan: 2 RPM, 500K tokens/min
#    WARNING: your data IS used for training on this plan
#    No credit card. Phone verification required.
#
#    1. Go to https://console.mistral.ai/
#    2. Sign up → choose "Experiment" plan (free) → verify phone
#    3. Go to "API Keys" → "Create new key"
# ---------------------------------------------------------------------------
MISTRAL_API_KEY=

# ---------------------------------------------------------------------------
# 6. NVIDIA NIM — 40 RPM, dozens of models including 405B
#    No credit card. Phone verification required.
#
#    1. Go to https://build.nvidia.com/
#    2. Sign in → verify phone
#    3. Click any model → "Get API Key"
#    4. Copy the key (starts with "nvapi-...")
# ---------------------------------------------------------------------------
NVIDIA_NIM_API_KEY=

# ---------------------------------------------------------------------------
# 7. CLOUDFLARE WORKERS AI — 10,000 neurons/day
#    Credit card required for $0 plan (never charged). No phone.
#
#    1. Go to https://dash.cloudflare.com/sign-up → add credit card
#    2. ACCOUNT ID: Dashboard → sidebar or URL bar → 32-char hex string
#       (like 023e105f4ecef8ad9ca31a8372d0c353 — NOT your email!)
#    3. API TOKEN: https://dash.cloudflare.com/profile/api-tokens
#       → "Create Token" → use "Workers AI" template
# ---------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# 8. OPENROUTER — 28+ free models, auto-routing
#    Free: 50 requests/day (1,000/day with $10 one-time lifetime topup)
#    No credit card. No phone.
#
#    1. Go to https://openrouter.ai/keys
#    2. Sign up → "Create Key"
#    3. Copy the key (starts with "sk-or-...")
#    4. Optional: add $10 at https://openrouter.ai/credits → 20x daily limit
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# 9. COHERE — emergency fallback, 1K requests/month
#    No credit card. No phone.
#
#    1. Go to https://dashboard.cohere.com/api-keys
#    2. Sign up → trial key is shown on dashboard
# ---------------------------------------------------------------------------
COHERE_API_KEY=

# ---------------------------------------------------------------------------
# LOCAL OLLAMA (optional — for the "local" alias, privacy-sensitive work)
# Leave empty if you don't have Ollama. Gateway works fine without it.
# Change the IP/hostname to match your Ollama server(s).
# ---------------------------------------------------------------------------
OLLAMA_HOST_1=
OLLAMA_HOST_2=
OLLAMA_HOST_3=
# V1-compatible endpoint (append /v1 to OLLAMA_HOST_1 if set)
OLLAMA_HOST_1_V1=

# ---------------------------------------------------------------------------
# GATEWAY CONFIGURATION (defaults work out of the box)
# ---------------------------------------------------------------------------
# LITELLM_BASE=http://localhost:4002    # LiteLLM proxy URL
# ROUTER_PORT=4000                      # Smart router port
# LOG_DIR=logs                          # Log directory (relative to project root)
# LOG_LEVEL=INFO                        # DEBUG, INFO, WARNING, ERROR
# CONFIG_PATH=litellm_config.yaml       # LiteLLM config file path
# GATEWAY_URL=http://localhost:4000     # Public gateway URL (for docs)
# REDIS_HOST=localhost                  # Redis host (required, started by start.sh)
# REDIS_PORT=6379                       # Redis port

# LLAMA.CPP (optional — if you have a llama.cpp server running)
# Supports OpenAI-compatible API on any host
LLAMA_CPP_HOST=
